# Easier navigation: .., ..., ...., ....., ~ and -
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ~="cd ~" # `cd` is probably faster to type though
alias -- -="cd -"

# Directory shortcuts
alias dotfiles="cd $DOTFILES"
alias library="cd $HOME/Library"

# Enable aliases to be sudo'ed
alias sudo='sudo '

# Detect which `ls` flavor is in use
if ls --color > /dev/null 2>&1; then # GNU `ls`
	colorflag="--color"
	export LS_COLORS='no=00:fi=00:di=01;31:ln=01;36:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:ex=01;32:*.tar=01;31:*.tgz=01;31:*.arj=01;31:*.taz=01;31:*.lzh=01;31:*.zip=01;31:*.z=01;31:*.Z=01;31:*.gz=01;31:*.bz2=01;31:*.deb=01;31:*.rpm=01;31:*.jar=01;31:*.jpg=01;35:*.jpeg=01;35:*.gif=01;35:*.bmp=01;35:*.pbm=01;35:*.pgm=01;35:*.ppm=01;35:*.tga=01;35:*.xbm=01;35:*.xpm=01;35:*.tif=01;35:*.tiff=01;35:*.png=01;35:*.mov=01;35:*.mpg=01;35:*.mpeg=01;35:*.avi=01;35:*.fli=01;35:*.gl=01;35:*.dl=01;35:*.xcf=01;35:*.xwd=01;35:*.ogg=01;35:*.mp3=01;35:*.wav=01;35:'
else # macOS `ls`
	colorflag="-G"
	export LSCOLORS='BxBxhxDxfxhxhxhxhxcxcx'
fi
# Always use color + classify output for `ls`
alias ls="command ls ${colorflag} -F"

# Always enable colored `grep` output
# Note: `GREP_OPTIONS="--color=auto"` is deprecated, hence the alias usage.
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Directory listings
alias l="ls -Glah"
alias la='ls -al'
alias ll='ls -lth'

# Directory trees
alias t="tree -L 1 --dirsfirst -shugp"
alias tt="tree -L 2 --dirsfirst"

# Get week number
alias week='date +%V'

# Reload the shell (i.e. invoke as a login shell)
alias reload="exec ${SHELL} -l"

# Print each PATH entry on a separate line
alias path='echo -e ${PATH//:/\\n}'

# Misc utilities
alias c="clear"
alias copyssh="pbcopy < $HOME/.ssh/id_ed25519.pub"
alias shrug="echo '¯\_(ツ)_/¯' | pbcopy"
alias plistbuddy="/usr/libexec/PlistBuddy"
alias brewb='brew bundle --file=~/.dotfiles/Brewfile'
alias rm='rm -i'
weather() { curl -4 "wttr.in/${1:-redondo+beach+ca}" }

# Flush Directory Service cache
alias flush="dscacheutil -flushcache && killall -HUP mDNSResponder"

# Clean up LaunchServices to remove duplicates in the "Open With" menu
alias lscleanup="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -kill -r -domain local -domain system -domain user && killall Finder"

# Recursively delete `.DS_Store` files
alias cleanup="find . -type f -name '*.DS_Store' ! -path './.DS_Store' ! -path './Desktop/.DS_Store' -ls -delete 2>/dev/null"

# Empty the Trash on all mounted volumes and the main HDD.
# Also, clear Apple's System Logs to improve shell startup speed.
# Finally, clear download history from quarantine. https://mths.be/bum
alias emptytrash="sudo rm -rfv /Volumes/*/.Trashes; sudo rm -rfv /private/var/log/asl/*.asl; sqlite3 ~/Library/Preferences/com.apple.LaunchServices.QuarantineEventsV* 'delete from LSQuarantineEvent'"

alias update_all='(
echo "brew update" && brew update
echo "brew upgrade" && brew upgrade
echo "brew update" && brew update
echo "brew upgrade" && brew upgrade
git -C $DOTFILES/plugins/zsh-autosuggestions pull --quiet && git -C $DOTFILES/plugins/zsh-syntax-highlighting pull --quiet && git -C $DOTFILES/themes/powerlevel10k pull --quiet && echo "zsh plugins up to date"
echo "mas upgrade" && mas upgrade
echo "brew tap --repair -v" && brew tap --repair -v
echo "brew cleanup -v" && brew cleanup -v
echo "uv tool upgrade --all" && uv tool upgrade --all
echo "uv cache clean" && uv cache clean
echo "pyenv cache clean" && rm -rf ~/.pyenv/cache/*
echo "yarn cache clean" && yarn cache clean
echo "xcrun simctl delete unavailable" && xcrun simctl delete unavailable
echo "gem cleanup" && gem cleanup && rbenv rehash
echo "flush" && flush
echo "cleanup" && (cd ~ && cleanup)
echo "lscleanup" && lscleanup
echo "brew bundle dump" && brew bundle dump --force --file="$HOME/.dotfiles/Brewfile"
echo "mackup backup" && mackup backup --force 2>/dev/null | grep -c "Backing up" | xargs -I{} echo "  {} files backed up"
echo "emptytrash" && emptytrash
)
omz_out=$(omz update 2>&1); echo "$omz_out" | grep -q "already at the latest" && echo "omz: already up to date" || echo "$omz_out"'

# Show/hide hidden files in Finder
alias show="defaults write com.apple.finder AppleShowAllFiles -bool true && killall Finder"
alias hide="defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder"

# Hide/show all desktop icons (useful when presenting)
alias hidedesktop="defaults write com.apple.finder CreateDesktop -bool false && killall Finder"
alias showdesktop="defaults write com.apple.finder CreateDesktop -bool true && killall Finder"

# Git
alias gs='git status '
alias ga='git add '
alias gb='git branch '
alias gc='git commit'
alias gco="git checkout"
alias gd='git diff'
alias gl="git log --oneline --decorate --color"
alias commit="git add . && git commit -m"
alias gcommit="git add . && git commit"
alias amend="git commit --amend --no-edit"
alias amendall="git add . && amend"
alias resolve="git add . && git commit --no-edit"
alias nuke="git clean -df && git reset --hard"
alias wip='git add . && git commit -m WIP && git push ${DEFAULT_GIT_REMOTE} $(git branch --show-current)'
alias dotfilepush="cd ~/.dotfiles && git add home/ && git commit -m \"sync dotfiles\" && git push origin master && cd -"
